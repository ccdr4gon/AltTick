<Window x:Class="AltTick.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.1"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootPanel" Opacity="0"
            CornerRadius="12"
            Padding="20"
            Background="#E0202020">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <!-- App name header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Center">
                <Image x:Name="AppIcon" Width="24" Height="24" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="AppNameText" Foreground="White" FontSize="16"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Thumbnails container -->
            <ItemsControl x:Name="ThumbnailContainer">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
